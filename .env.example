# Copy this file to .env and fill in the values for local development.
# Never commit .env to git.

# Django
SECRET_KEY=django-insecure-replace-with-a-real-secret-key-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for local dev; Railway provides DATABASE_URL automatically for production)
DATABASE_URL=sqlite:///db.sqlite3

# Redis (required in production for Channels and Celery; not needed in local dev with InMemoryChannelLayer)
REDIS_URL=redis://localhost:6379/0

# Email (optional for local dev — console backend is used by default)
DEFAULT_FROM_EMAIL=noreply@mlmonitor.local
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
