# Copy this file to .env.docker and fill in the values before running docker-compose.
# Never commit .env.docker to git.

# Django
SECRET_KEY=replace-with-a-real-50-char-secret-key
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production

# These point to the Docker service names defined in docker-compose.yml
DATABASE_URL=postgres://mlmonitor:mlmonitor@db:5432/mlmonitor
REDIS_URL=redis://redis:6379/0

ALLOWED_HOSTS=localhost,127.0.0.1

DEFAULT_FROM_EMAIL=noreply@mlmonitor.local
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
